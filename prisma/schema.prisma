// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  EMPLOYEE
  CUSTOMER
}

enum StaffAccessLevel {
  MANAGER
  SELLER
}

enum RetailOrderStatus {
  PENDING_TRANSFER
  TRANSFER_REPORTED
  CONFIRMED
  CANCELLED
}

enum BillingMode {
  NEGRO
  BLANCO
}

enum PriceModeCart {
  RETAIL
  WHOLESALE
}

enum WholesaleRequestStatus {
  NUEVO
  CONTACTADO
  COTIZADO
  CERRADO
  CANCELADO
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Consultas web desde /mayorista/contacto (sin cuenta de cliente).
enum WholesaleLeadStatus {
  NUEVO
  CONTACTADO
  CERRADO
  DESCARTADO
}

model WholesaleLead {
  id              String              @id @default(cuid())
  companyName     String
  contactName     String
  email           String
  phone           String
  taxId           String?
  estimatedVolume String?
  message         String
  status          WholesaleLeadStatus @default(NUEVO)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  staffAccessLevel StaffAccessLevel?
  /// Clientes deben verificar email antes de comprar; staff suele tener fecha fijada en el alta.
  emailVerified            DateTime?
  emailVerificationTokenHash String?
  emailVerificationExpires   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cart                     Cart?
  retailOrders             RetailOrder[]              @relation("CustomerRetailOrders")
  wholesaleRequests        WholesaleRequest[]         @relation("CustomerWholesaleRequests")
  assignedWholesaleRequests WholesaleRequest[]        @relation("AssignedWholesaleRequests")
  wholesaleRequestEvents   WholesaleRequestEvent[]
  approvalRequestsCreated  ApprovalRequest[]         @relation("ApprovalRequester")
  approvalRequestsResolved ApprovalRequest[]         @relation("ApprovalResolver")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id                       String            @id @default(cuid())
  name                     String
  slug                     String            @unique
  supplierName             String?
  description              String
  /// Imagen por defecto si la variante no tiene imagen propia.
  imageUrl                 String
  listPrice                Decimal           @db.Decimal(10, 2)
  retailPrice              Decimal           @db.Decimal(10, 2)
  wholesalePrice           Decimal           @db.Decimal(10, 2)
  discountRetailPercent    Int               @default(0)
  discountWholesalePercent Int               @default(0)
  isActive                 Boolean           @default(true)
  isBestSeller             Boolean           @default(false)
  categoryId               String
  category                 Category          @relation(fields: [categoryId], references: [id])
  variants                 ProductVariant[]
  retailItems              RetailOrderItem[]
  wholesaleRequestItems    WholesaleRequestItem[]
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
}

/// Misma ficha de producto; la única diferencia visible suele ser el color (u otra variante simple).
model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorLabel String
  imageUrl  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  cartItems CartItem[]
  retailOrderItems RetailOrderItem[]
  wholesaleRequestItems WholesaleRequestItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, colorLabel])
}

model Cart {
  id        String        @id @default(cuid())
  userId    String        @unique
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode      PriceModeCart @default(RETAIL)
  items     CartItem[]
  updatedAt DateTime      @updatedAt
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int            @default(1)

  @@unique([cartId, variantId])
}

/// Pedido minorista (transferencia). Sin envío de mail al cliente en flujo final.
model RetailOrder {
  id             String            @id @default(cuid())
  customerId     String?
  customer       User?             @relation("CustomerRetailOrders", fields: [customerId], references: [id])
  buyerName      String
  buyerEmail     String
  buyerPhone     String?
  notes          String?
  billingMode    BillingMode       @default(BLANCO)
  totalAmount    Decimal           @db.Decimal(10, 2)
  status         RetailOrderStatus @default(PENDING_TRANSFER)
  transferAlias  String
  transferCbu    String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  items          RetailOrderItem[]
}

model RetailOrderItem {
  id                 String          @id @default(cuid())
  orderId            String
  productId          String
  variantId          String?
  productName        String
  variantColorLabel String?
  unitPrice          Decimal         @db.Decimal(10, 2)
  quantity           Int             @default(1)
  subtotal           Decimal         @db.Decimal(10, 2)
  order              RetailOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product         @relation(fields: [productId], references: [id])
  variant            ProductVariant? @relation(fields: [variantId], references: [id])
}

/// Solicitud mayorista con ítems; gestión en pantalla empleado/owner.
model WholesaleRequest {
  id             String                 @id @default(cuid())
  status         WholesaleRequestStatus   @default(NUEVO)
  customerId     String
  customer       User                   @relation("CustomerWholesaleRequests", fields: [customerId], references: [id])
  companyName    String
  cuit           String
  contactName    String
  email          String
  phone          String?
  address        String?
  notes          String?
  assignedToId   String?
  assignedTo     User?                  @relation("AssignedWholesaleRequests", fields: [assignedToId], references: [id])
  items          WholesaleRequestItem[]
  events         WholesaleRequestEvent[]
  approvals      ApprovalRequest[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model WholesaleRequestItem {
  id                  String             @id @default(cuid())
  requestId           String
  request             WholesaleRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  productId           String
  variantId           String?
  product             Product            @relation(fields: [productId], references: [id])
  variant             ProductVariant?    @relation(fields: [variantId], references: [id])
  productNameSnapshot String
  colorLabelSnapshot  String?
  unitPrice           Decimal            @db.Decimal(10, 2)
  quantity            Int                @default(1)
  subtotal            Decimal            @db.Decimal(10, 2)
}

model WholesaleRequestEvent {
  id         String             @id @default(cuid())
  requestId  String
  request    WholesaleRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?              @relation(fields: [userId], references: [id])
  action     String
  payload    Json?
  createdAt  DateTime           @default(now())
}

model ApprovalRequest {
  id                   String              @id @default(cuid())
  wholesaleRequestId   String
  wholesaleRequest     WholesaleRequest    @relation(fields: [wholesaleRequestId], references: [id], onDelete: Cascade)
  requestedById        String
  requestedBy          User                @relation("ApprovalRequester", fields: [requestedById], references: [id])
  type                 String
  note                 String?
  status               ApprovalStatus      @default(PENDING)
  resolvedById         String?
  resolvedBy           User?               @relation("ApprovalResolver", fields: [resolvedById], references: [id])
  resolutionNote       String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

/// Carrusel / banners administrables desde backoffice.
model Banner {
  id        String    @id @default(cuid())
  title     String?
  imageUrl  String
  linkUrl   String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
