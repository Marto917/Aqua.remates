DATABASE_URL="postgresql://user:password@localhost:5432/aqua?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-largo"
# Mientras no uses login: permite entrar a /admin y /vendedor y APIs admin sin sesion
# Valores aceptados: true, 1, yes, si (tambien NEXT_PUBLIC_BACKOFFICE_PREVIEW en Vercel)
BACKOFFICE_PREVIEW="true"
NEXT_PUBLIC_BACKOFFICE_PREVIEW="true"

# Railway/Postgres (produccion)
# 1) Crear Postgres en Railway
# 2) Copiar DATABASE_URL al servicio web
# 3) Setear NEXTAUTH_URL a tu URL publica de Railway (https://... )

# Imagenes persistentes (Railway)
# Recomendado: montar un Volume en el servicio web apuntando a la carpeta:
#   <repo>/public/uploads/products
# y NO hace falta tocar nada (dejá AQUA_UPLOADS_DIR vacío).
# Si por alguna razón querés otra ruta en disco, usá ruta absoluta:
# AQUA_UPLOADS_DIR="/ruta/absoluta/uploads/products"

# Imagenes en produccion (recomendado: Cloudinary)
# En Railway, en el servicio web:
# STORAGE="cloudinary"
# CLOUDINARY_CLOUD_NAME="tu_cloud_name"
# Y una de estas dos opciones:
# CLOUDINARY_UNSIGNED_PRESET="..."   # subida "unsigned" con upload preset
# o firma con API (sin preset hace falta key+secret):
# CLOUDINARY_API_KEY="..."
# CLOUDINARY_API_SECRET="..."
# (opcional) CLOUDINARY_FOLDER="aqua/products"
# CLOUDINARY_URL="cloudinary://<key>:<secret>@<cloud_name>"  # alternativa a CLOUDINARY_CLOUD_NAME
